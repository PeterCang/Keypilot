{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Keypilot",
  "version": "0.1.0",
  "identifier": "com.keypilot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Keypilot",
        "width": 1080,
        "height": 760
      }
    ],
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "uacSettings": {
        "level": "requireAdministrator",
        "uiAccess": false
      }
    }
  }
}
